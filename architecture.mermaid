graph TB
    subgraph "Customer Touchpoints"
        A1[Web Form / Chat] 
        A2[Email Inbox]
        A3[Marketing Brief]
    end

    subgraph "n8n Orchestration Layer"
        direction TB
        
        subgraph "WF1: Smart Booking"
            B1[Webhook Trigger] --> B2[AI Process Booking]
            B2 --> B3{Intent Check}
            B3 -->|Book| B4[Check Calendar]
            B4 --> B5{Available?}
            B5 -->|Yes| B6[Create Event]
            B6 --> B7[Send Confirmation]
            B5 -->|No| B8[Suggest Alternative]
            B3 -->|Enquiry| B9[Route to Team]
        end

        subgraph "WF2: Support Triage"
            C1[Webhook Trigger] --> C2[AI Triage]
            C2 --> C3[Log Ticket]
            C2 --> C4{Route by Category}
            C4 -->|Product Q| C5{Confidence?}
            C5 -->|High| C6[Auto Reply]
            C5 -->|Low| C7[Escalate]
            C4 -->|Complaint| C8[Escalate to Manager]
            C4 -->|Billing| C9[Forward to Billing]
            C4 -->|Returns| C10[Forward to Returns]
        end

        subgraph "WF3: Content Pipeline"
            D1[Webhook Trigger] --> D2[Validate Brief]
            D2 --> D3[AI Generate Content]
            D3 --> D4{Success?}
            D4 -->|Yes| D5[Format & Organise]
            D5 --> D6[Email / Social / Product]
            D6 --> D7[Send for Review]
            D4 -->|No| D8[Retry / Fallback]
        end
    end

    subgraph "AI Backend - FastAPI on Railway"
        E1["/api/booking/process"]
        E2["/api/support/triage"]
        E3["/api/content/generate"]
        E4[OpenAI GPT-4o-mini]
    end

    subgraph "Integrations"
        F1[Google Calendar API]
        F2[Email SMTP]
        F3[Error Logging]
    end

    A1 --> B1
    A2 --> C1
    A3 --> D1
    
    B2 --> E1
    C2 --> E2
    D3 --> E3
    
    E1 --> E4
    E2 --> E4
    E3 --> E4
    
    B4 --> F1
    B6 --> F1
    B7 --> F2
    C6 --> F2
    C7 --> F2
    D7 --> F2

    style B1 fill:#e8f5e9
    style C1 fill:#e3f2fd
    style D1 fill:#fff3e0
    style E4 fill:#f3e5f5
    style F1 fill:#fce4ec
